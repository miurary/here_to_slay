# =========================
# TypeScript
# =========================
*.tsbuildinfo

# =========================
# Dependencies
# =========================
node_modules/

# =========================
# Frontend Build Outputs
# =========================
# Vite uses 'dist' by default, CRA uses 'build'
dist/
dist-ssr/
build/

# =========================
# Environment Variables
# =========================
# NEVER commit your secrets, API keys, or database passwords!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# =========================
# Logs and Debugging
# =========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log

# =========================
# Testing
# =========================
coverage/

# =========================
# OS Generated Files
# =========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =========================
# Editor / IDE settings
# =========================
# You generally want to ignore local editor settings to avoid conflicts with teammates
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
# =========================
# Game analytics event logs (JSONL, may contain hidden-info hands)
# =========================
analytics/
