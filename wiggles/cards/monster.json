{
    "m_001": {
        "id": "m_001",
        "name": "Doombringer",
        "type": "monster",
        "requirements": [
            { "class": "necromancer", "amount": 1},
            { "class": "hero", "amount": 1}
        ],
        "lowerBound": 4,
        "lowerBoundEffect": [
            { "action": "DISCARD", "amount": -1, "target": "self" }
        ],
        "lowerBoundText": "DISCARD your hand",
        "upperBound": 8,
        "upperBoundEffect": [
            { "action": "SLAY", "target": "monster"}
        ],
        "upperBoundText": "SLAY this Monster card",
        "slainEffect": {
            "triggerEvent": "ON_SACRIFICE",
            "isOptional": true,
            "action": "PROMPT_SELECT",
            "zoneToSelectFrom": "discard_pile",
            "amount": 1,
            "destination": "hand"
        },
        "slainEffectText": "Each time you SACRIFICE a card, you may choose a card from the discard pile and add it to your hand."
    },
    "m_002": {
